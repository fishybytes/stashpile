#!/bin/bash
# Usage: ./infrastructure/scripts/tf <env> <terraform command...>
# Example: ./infrastructure/scripts/tf dev apply
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$SCRIPT_DIR/../.."

ENV="$1"
if [ -z "$ENV" ]; then
  echo "Usage: tf <environment> <terraform args>"
  echo "  e.g. tf dev apply"
  exit 1
fi

ENV_FILE="$ROOT/.env.$ENV"
ENV_DIR="$SCRIPT_DIR/../environments/$ENV"

if [ ! -d "$ENV_DIR" ]; then
  echo "Error: no environment directory at $ENV_DIR"
  exit 1
fi

# Load local credentials if present; in CI, credentials come from OIDC
if [ -f "$ENV_FILE" ]; then
  set -a && source "$ENV_FILE" && set +a
elif [ -z "$AWS_ACCESS_KEY_ID" ] && [ -z "$AWS_WEB_IDENTITY_TOKEN_FILE" ]; then
  echo "Error: no credentials found. Create $ENV_FILE or set AWS env vars."
  exit 1
fi

cd "$ENV_DIR"
terraform "${@:2}"
