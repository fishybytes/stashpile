#!/bin/bash
# Loads project-level AWS credentials and runs terraform
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$SCRIPT_DIR/../../.env"

if [ ! -f "$ENV_FILE" ]; then
  echo "Error: .env file not found at $ENV_FILE"
  exit 1
fi

set -a && source "$ENV_FILE" && set +a

cd "$SCRIPT_DIR/../terraform"
terraform "$@"
