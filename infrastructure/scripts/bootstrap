#!/bin/bash
# Creates the S3 bucket used for Terraform remote state.
# Run once per AWS account before `tf <env> init`.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$SCRIPT_DIR/../.."

ENV="${1:-dev}"
ENV_FILE="$ROOT/.env.$ENV"

if [ -f "$ENV_FILE" ]; then
  set -a && source "$ENV_FILE" && set +a
elif [ -z "$AWS_ACCESS_KEY_ID" ] && [ -z "$AWS_WEB_IDENTITY_TOKEN_FILE" ]; then
  echo "Error: no credentials found. Create $ENV_FILE or set AWS env vars."
  exit 1
fi

ACCOUNT_ID=$(aws sts get-caller-identity --query Account --output text)
BUCKET="stashpile-tfstate-$ACCOUNT_ID"
REGION="${AWS_DEFAULT_REGION:-us-east-1}"

echo "[$ENV] Creating Terraform state bucket: $BUCKET"

aws s3api create-bucket --bucket "$BUCKET" --region "$REGION" 2>/dev/null || echo "  Bucket already exists, continuing."

aws s3api put-bucket-versioning \
  --bucket "$BUCKET" \
  --versioning-configuration Status=Enabled

aws s3api put-public-access-block \
  --bucket "$BUCKET" \
  --public-access-block-configuration "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true"

echo "[$ENV] State bucket ready: s3://$BUCKET"
echo ""
echo "Now run: ./infrastructure/scripts/tf $ENV init"
