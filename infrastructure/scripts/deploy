#!/bin/bash
# Usage: ./infrastructure/scripts/deploy <env>
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$SCRIPT_DIR/../.."

ENV="${1:-dev}"
ENV_FILE="$ROOT/.env.$ENV"

# Load local credentials if present; in CI, credentials come from OIDC
if [ -f "$ENV_FILE" ]; then
  set -a && source "$ENV_FILE" && set +a
elif [ -z "$AWS_ACCESS_KEY_ID" ] && [ -z "$AWS_WEB_IDENTITY_TOKEN_FILE" ]; then
  echo "Error: no credentials found. Create $ENV_FILE or set AWS env vars."
  exit 1
fi

cd "$SCRIPT_DIR/../environments/$ENV"
INSTANCE_ID=$(terraform output -raw instance_id 2>/dev/null)
BUCKET=$(terraform output -raw s3_bucket 2>/dev/null)
BACKEND_INSTANCE_ID=$(terraform output -raw backend_instance_id 2>/dev/null)

if [ -z "$INSTANCE_ID" ] || [ -z "$BUCKET" ]; then
  echo "Error: run ./infrastructure/scripts/tf $ENV apply first."
  exit 1
fi

# ─── Upload both apps to S3 ───────────────────────────────────────────────────

echo "[$ENV] Syncing mobile code to s3://$BUCKET/apps/mobile/..."
aws s3 sync "$ROOT/apps/mobile/" "s3://$BUCKET/apps/mobile/" \
  --exclude "node_modules/*" \
  --exclude ".expo/*" \
  --exclude "*.orig.*" \
  --delete

echo "[$ENV] Syncing backend code to s3://$BUCKET/apps/backend/..."
aws s3 sync "$ROOT/apps/backend/" "s3://$BUCKET/apps/backend/" \
  --exclude "__pycache__/*" \
  --exclude "*.pyc" \
  --delete

# ─── Deploy to Expo server ────────────────────────────────────────────────────

echo "[$ENV] Triggering mobile deploy on $INSTANCE_ID..."
COMMAND_ID=$(aws ssm send-command \
  --instance-ids "$INSTANCE_ID" \
  --document-name "AWS-RunShellScript" \
  --parameters '{"commands":["/usr/local/bin/stashpile-deploy"]}' \
  --query "Command.CommandId" \
  --output text)

aws ssm wait command-executed \
  --command-id "$COMMAND_ID" \
  --instance-id "$INSTANCE_ID"

STATUS=$(aws ssm get-command-invocation \
  --command-id "$COMMAND_ID" \
  --instance-id "$INSTANCE_ID" \
  --query "Status" --output text)

if [ "$STATUS" != "Success" ]; then
  echo "[$ENV] Mobile deploy failed (status: $STATUS)."
  exit 1
fi
echo "[$ENV] Mobile deploy complete."

# ─── Deploy to backend API server ─────────────────────────────────────────────

if [ -n "$BACKEND_INSTANCE_ID" ]; then
  echo "[$ENV] Triggering backend deploy on $BACKEND_INSTANCE_ID..."
  BACKEND_CMD_ID=$(aws ssm send-command \
    --instance-ids "$BACKEND_INSTANCE_ID" \
    --document-name "AWS-RunShellScript" \
    --parameters '{"commands":["/usr/local/bin/stashpile-backend-deploy"]}' \
    --query "Command.CommandId" \
    --output text)

  aws ssm wait command-executed \
    --command-id "$BACKEND_CMD_ID" \
    --instance-id "$BACKEND_INSTANCE_ID"

  BACKEND_STATUS=$(aws ssm get-command-invocation \
    --command-id "$BACKEND_CMD_ID" \
    --instance-id "$BACKEND_INSTANCE_ID" \
    --query "Status" --output text)

  if [ "$BACKEND_STATUS" != "Success" ]; then
    echo "[$ENV] Backend deploy failed (status: $BACKEND_STATUS)."
    exit 1
  fi
  echo "[$ENV] Backend deploy complete."
else
  echo "[$ENV] No backend instance found, skipping backend deploy."
fi
